<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Top Header -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp">

                <ImageView
                    android:id="@+id/logo_icon"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@drawable/ic_logo_brand"
                    android:contentDescription="@string/desc_app_logo" />

                <TextView
                    android:id="@+id/app_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_toEndOf="@id/logo_icon"
                    android:layout_toStartOf="@id/location_container"
                    android:text="@string/app_name"
                    android:textColor="@color/colorPrimary"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:ellipsize="end"
                    android:maxLines="1" />

                <LinearLayout
                    android:id="@+id/location_container"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@android:drawable/ic_menu_mylocation"
                        app:tint="@color/colorPrimary"
                        android:contentDescription="@null" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:text="@string/location_bangalore"
                        android:textColor="@color/colorTextSecondary"
                        android:textSize="12sp" />
                </LinearLayout>
            </RelativeLayout>

            <!-- Main Input Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/colorSurface"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/chip_unselected"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Header Image with Title Overlay -->
                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="160dp">

                        <!-- IMPORTANT: Replace this src with your image once added to res/drawable -->
                        <com.google.android.material.imageview.ShapeableImageView
                            android:id="@+id/banner_image"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop"
                            android:src="@drawable/banner_wall"
                            app:shapeAppearanceOverlay="@style/ShapeAppearance.NammaMistri.MediumComponent"
                            android:contentDescription="@null" />

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="#4D000000" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="bottom|start"
                            android:layout_margin="16dp"
                            android:text="@string/material_calculator"
                            android:textColor="@color/colorSurface"
                            android:textSize="22sp"
                            android:textStyle="bold" />
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <!-- Length -->
                        <TextView
                            style="@style/SectionHeader"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/label_length_bilingual"
                            android:textColor="@color/colorTextSecondary"
                            android:textSize="11sp" />

                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:layout_marginBottom="16dp"
                            app:boxStrokeColor="@color/colorTextSecondary"
                            app:suffixText="@string/unit_ft">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/length_input"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:hint="@string/hint_enter_length"
                                android:inputType="numberDecimal"
                                android:textColor="@color/colorTextPrimary" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <!-- Height -->
                        <TextView
                            style="@style/SectionHeader"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/label_height_bilingual"
                            android:textColor="@color/colorTextSecondary"
                            android:textSize="11sp" />

                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:layout_marginBottom="16dp"
                            app:boxStrokeColor="@color/colorTextSecondary"
                            app:suffixText="@string/unit_ft">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/height_input"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:hint="@string/hint_enter_height"
                                android:inputType="numberDecimal"
                                android:textColor="@color/colorTextPrimary" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <!-- Thickness -->
                        <TextView
                            style="@style/SectionHeader"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/label_thickness_bilingual"
                            android:textColor="@color/colorTextSecondary"
                            android:textSize="11sp" />

                        <com.google.android.material.button.MaterialButtonToggleGroup
                            android:id="@+id/thickness_toggle_group"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:layout_marginBottom="16dp"
                            app:checkedButton="@+id/btn_9"
                            app:singleSelection="true">

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btn_4_5"
                                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/thickness_4_5"
                                android:textColor="@color/colorOnSurface" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btn_9"
                                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/thickness_9"
                                android:textColor="@color/colorOnSurface" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btn_13_5"
                                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/thickness_13_5"
                                android:textColor="@color/colorOnSurface" />
                        </com.google.android.material.button.MaterialButtonToggleGroup>

                        <!-- Wastage -->
                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="4dp">

                            <TextView
                                android:id="@+id/wastage_label"
                                style="@style/SectionHeader"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentStart="true"
                                android:layout_toStartOf="@+id/wastage_value_text"
                                android:text="@string/label_wastage_bilingual"
                                android:textColor="@color/colorTextSecondary"
                                android:textSize="11sp" />

                            <TextView
                                android:id="@+id/wastage_value_text"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentEnd="true"
                                android:text="10%"
                                android:textColor="@color/colorPrimary"
                                android:textSize="20sp"
                                android:textStyle="bold"
                                tools:ignore="HardcodedText" />
                        </RelativeLayout>

                        <com.google.android.material.slider.Slider
                            android:id="@+id/wastage_slider"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="24dp"
                            android:value="10"
                            android:valueFrom="0"
                            android:valueTo="20"
                            app:labelBehavior="gone" />

                        <!-- Calculate Button -->
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/calculate_button"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:backgroundTint="@color/colorPrimary"
                            android:text="@string/btn_calculate"
                            android:textColor="@color/colorSurface"
                            app:cornerRadius="12dp"
                            app:icon="@android:drawable/ic_menu_send"
                            app:iconTint="@color/colorSurface" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Results Section -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/results_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="32dp"
                app:cardBackgroundColor="@color/colorSurface"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/colorPrimary"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@color/colorPrimary"
                        android:padding="16dp"
                        android:text="@string/estimation_results"
                        android:textColor="@color/colorSurface"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <!-- Bricks Row -->
                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="16dp">

                            <com.google.android.material.card.MaterialCardView
                                android:id="@+id/brick_icon_container"
                                android:layout_width="48dp"
                                android:layout_height="48dp"
                                app:cardBackgroundColor="@color/bg_result_bricks"
                                app:cardCornerRadius="8dp"
                                app:cardElevation="0dp">

                                <ImageView
                                    android:layout_width="24dp"
                                    android:layout_height="24dp"
                                    android:layout_gravity="center"
                                    android:src="@drawable/ic_bricks"
                                    app:tint="@color/tint_result_bricks"
                                    android:contentDescription="@null" />
                            </com.google.android.material.card.MaterialCardView>

                            <LinearLayout
                                android:id="@+id/brick_text_container"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_centerVertical="true"
                                android:layout_marginStart="16dp"
                                android:layout_toEndOf="@id/brick_icon_container"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/label_bricks_bilingual"
                                    android:textColor="@color/colorTextSecondary"
                                    android:textSize="12sp" />

                                <LinearLayout
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:orientation="horizontal">

                                    <TextView
                                        android:id="@+id/bricks_result"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="@string/mock_bricks"
                                        android:textColor="@color/colorTextPrimary"
                                        android:textSize="22sp"
                                        android:textStyle="bold" />

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginStart="4dp"
                                        android:text="@string/unit_pcs"
                                        android:textColor="@color/colorTextSecondary"
                                        android:textSize="14sp" />
                                </LinearLayout>
                            </LinearLayout>
                        </RelativeLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginBottom="16dp"
                            android:background="@color/divider" />

                        <!-- Cement Row -->
                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="16dp">

                            <com.google.android.material.card.MaterialCardView
                                android:id="@+id/cement_icon_container"
                                android:layout_width="48dp"
                                android:layout_height="48dp"
                                app:cardBackgroundColor="@color/bg_result_cement"
                                app:cardCornerRadius="8dp"
                                app:cardElevation="0dp">

                                <ImageView
                                    android:layout_width="24dp"
                                    android:layout_height="24dp"
                                    android:layout_gravity="center"
                                    android:src="@drawable/ic_cement"
                                    app:tint="@color/tint_result_cement"
                                    android:contentDescription="@null" />
                            </com.google.android.material.card.MaterialCardView>

                            <LinearLayout
                                android:id="@+id/cement_text_container"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_centerVertical="true"
                                android:layout_marginStart="16dp"
                                android:layout_toEndOf="@id/cement_icon_container"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/label_cement_bilingual"
                                    android:textColor="@color/colorTextSecondary"
                                    android:textSize="12sp" />

                                <LinearLayout
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:orientation="horizontal">

                                    <TextView
                                        android:id="@+id/cement_result"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="@string/mock_cement"
                                        android:textColor="@color/colorTextPrimary"
                                        android:textSize="22sp"
                                        android:textStyle="bold" />

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginStart="4dp"
                                        android:text="@string/unit_bags"
                                        android:textColor="@color/colorTextSecondary"
                                        android:textSize="14sp" />
                                </LinearLayout>
                            </LinearLayout>
                        </RelativeLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginBottom="16dp"
                            android:background="@color/divider" />

                        <!-- Sand Row -->
                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="16dp">

                            <com.google.android.material.card.MaterialCardView
                                android:id="@+id/sand_icon_container"
                                android:layout_width="48dp"
                                android:layout_height="48dp"
                                app:cardBackgroundColor="@color/bg_result_sand"
                                app:cardCornerRadius="8dp"
                                app:cardElevation="0dp">

                                <ImageView
                                    android:layout_width="24dp"
                                    android:layout_height="24dp"
                                    android:layout_gravity="center"
                                    android:src="@drawable/ic_sand"
                                    app:tint="@color/tint_result_sand"
                                    android:contentDescription="@null" />
                            </com.google.android.material.card.MaterialCardView>

                            <LinearLayout
                                android:id="@+id/sand_text_container"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_centerVertical="true"
                                android:layout_marginStart="16dp"
                                android:layout_toEndOf="@id/sand_icon_container"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/label_sand_bilingual"
                                    android:textColor="@color/colorTextSecondary"
                                    android:textSize="12sp" />

                                <LinearLayout
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:orientation="horizontal">

                                    <TextView
                                        android:id="@+id/sand_result"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="@string/mock_sand"
                                        android:textColor="@color/colorTextPrimary"
                                        android:textSize="22sp"
                                        android:textStyle="bold" />

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginStart="4dp"
                                        android:text="@string/unit_loads"
                                        android:textColor="@color/colorTextSecondary"
                                        android:textSize="14sp" />
                                </LinearLayout>
                            </LinearLayout>
                        </RelativeLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginBottom="16dp"
                            android:background="@color/divider" />

                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">

                            <TextView
                                android:id="@+id/cost_disclaimer_text"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_centerVertical="true"
                                android:layout_alignParentStart="true"
                                android:layout_toStartOf="@+id/btn_share"
                                android:text="@string/cost_disclaimer"
                                android:textColor="@color/colorTextSecondary"
                                android:textSize="12sp" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btn_share"
                                style="@style/Widget.MaterialComponents.Button.TextButton"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentEnd="true"
                                android:text="@string/btn_share"
                                android:textColor="@color/colorTextSecondary"
                                app:icon="@android:drawable/ic_menu_share"
                                app:iconTint="@color/colorTextSecondary" />
                        </RelativeLayout>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
